# Copy to .env.local in the SAME folder as package.json (project root). One line per variable — no line break after "=".
# Restart `npm run dev` after any change (Vite reads env at startup).

# Supabase → Project Settings → API: Project URL + anon public key (never commit real keys; use .env.local only).

# Run supabase/migrations SQL in order in the Supabase SQL editor.
# Auth → URL configuration: set Site URL to the URL you use in the browser (e.g. http://localhost:5173 or :5174).
# Auth signup / magic link / password reset emails use the auth-send-email Edge Function + MailerSend
# (same NOTIFICATION_FROM_EMAIL as order emails). Dashboard → Authentication → Auth Hooks → Send Email → HTTPS
# → https://<project-ref>.supabase.co/functions/v1/auth-send-email — generate SEND_EMAIL_HOOK_SECRET there.
# Keep Confirm email ON. Deploy: npm run deploy:email-functions (includes auth-send-email).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local-only catalog import script. Get it from Supabase → Project Settings → API → service_role.
# Keep this only in .env.local or your shell. Never expose it in frontend code or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Import catalog rows from CSV:
#   npm run catalog:dry-run
#   npm run catalog:import

# KicksDB/Kicks Dev product import. Get a key from https://kicks.dev/api-keys.
# Keep the real key in .env.local only.
KICKSDB_API_KEY=replace-with-kicksdb-key
#   npm run kicks:dry-run
#   npm run kicks:import

# --- Stripe (Supabase Edge Functions secrets, not Vite) ---
# Set in Dashboard → Project Settings → Edge Functions → Secrets, or (with Supabase CLI linked):
# If `supabase` is not recognized (e.g. Windows without global CLI), use: npx supabase@latest <same args>
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set CHECKOUT_SITE_URL=http://localhost:5173
#   supabase secrets set CLEANUP_SECRET=<random-long-string>
# Buyer pays outbound shipping in Checkout; seller inbound label is deducted from payout.
# Amounts are cents. Defaults in code: buyer shipping $14.95, seller inbound label $9.95.
#   supabase secrets set BUYER_SHIPPING_CENTS=1495
#   supabase secrets set SELLER_INBOUND_LABEL_CENTS=995
# Optional seller/platform fee deducted from payout (basis points, e.g. 500 = 5%):
#   supabase secrets set SELLER_FEE_BPS=0
#
# Email notifications (Supabase Edge secrets only — not .env.local):
#
# Option A — MailerSend SMTP (recommended if you use SMTP in the MailerSend dashboard):
#   npx supabase@latest secrets set EMAIL_TRANSPORT=smtp
#   npx supabase@latest secrets set SMTP_HOST=smtp.mailersend.net
#   npx supabase@latest secrets set SMTP_PORT=587
#   npx supabase@latest secrets set SMTP_USER=your_smtp_username_from_mailersend
#   npx supabase@latest secrets set SMTP_PASSWORD=your_smtp_password_from_mailersend
#   npx supabase@latest secrets set NOTIFICATION_FROM_EMAIL="EXCH. <noreply@YOUR-SUBDOMAIN.mlsender.net>"
# MailerSend → Domains → your domain → SMTP → Generate new user (username is NOT the From address).
#
# Option B — MailerSend HTTP API:
#   npx supabase@latest secrets set MAILERSEND_API_KEY=mlsn_your_token
#   npx supabase@latest secrets set NOTIFICATION_FROM_EMAIL="EXCH. <noreply@YOUR-SUBDOMAIN.mlsender.net>"
#
# If SMTP_USER + SMTP_PASSWORD are set without EMAIL_TRANSPORT, SMTP is used automatically.
# Deploy: npm run deploy:email-functions — test: Admin → Send test email (check transport in JSON).
#
# Shippo seller-to-EXCH prepaid labels:
#   supabase secrets set SHIPPO_API_TOKEN=shippo_test_...
#   supabase secrets set EXCH_SHIP_TO_NAME="EXCH Verification"
#   supabase secrets set EXCH_SHIP_TO_STREET1="123 Main St"
#   supabase secrets set EXCH_SHIP_TO_CITY="Miami"
#   supabase secrets set EXCH_SHIP_TO_STATE="FL"
#   supabase secrets set EXCH_SHIP_TO_ZIP="33101"
#   supabase secrets set EXCH_SHIP_TO_COUNTRY=US
# Optional:
#   supabase secrets set EXCH_SHIP_TO_PHONE="3055550100"
#   supabase secrets set EXCH_SHIP_TO_EMAIL="verification@example.com"
#   supabase secrets set SHIPPO_SERVICELEVEL_TOKEN=usps_priority
#   supabase secrets set SHIPPO_LABEL_FILE_TYPE=PDF_4x6
#
# Deploy functions (from repo root, with Supabase CLI linked):
#   supabase functions deploy admin-update-trade-status
#   supabase functions deploy confirm-checkout-session
#   supabase functions deploy create-checkout-session
#   supabase functions deploy create-connect-account-link
#   supabase functions deploy create-buyer-outbound-label
#   supabase functions deploy create-seller-inbound-label
#   supabase functions deploy release-seller-payout
#   supabase functions deploy stripe-webhook --no-verify-jwt
#   supabase functions deploy cleanup-pending-trades --no-verify-jwt
#   supabase functions deploy send-test-email
#   supabase functions deploy auth-send-email --no-verify-jwt
# After setting MAILERSEND_API_KEY + NOTIFICATION_FROM_EMAIL, sign in as an admin and use Admin → “Send test email”.
#
# Stripe Dashboard → Developers → Webhooks → Add endpoint:
#   https://<project-ref>.supabase.co/functions/v1/stripe-webhook
#   Events: checkout.session.completed, checkout.session.expired
#
# Stripe Dashboard → Settings → Branding:
#   Business name: EXCH.
#   Accent color: #9D00FF
#   Icon/logo: upload your EXCH. mark
# Checkout is hosted by Stripe, so layout is fixed. The Edge Function controls item title/image,
# card-only payment collection, phone, shipping address, promo codes, and verification copy.
#
# After migrations 20250513120000_stripe_checkout.sql and 20250513143000_payment_lifecycle.sql:
# sellers can click Connect Stripe on /account instead of manually setting profiles.stripe_account_id.
# Stale reservations: POST cleanup-pending-trades with header x-cleanup-secret (optional JSON body).
#   { "minutes": 30 }  — release reserved trades older than N minutes (run every 15–30 min via cron).
# In-app notifications older than 7 days (when pg_cron is not available on your plan):
#   { "purge_notifications": true }  — run weekly on the same endpoint, e.g. cron-job.org Sundays:
#   curl -X POST "https://<project-ref>.supabase.co/functions/v1/cleanup-pending-trades" \
#     -H "x-cleanup-secret: YOUR_CLEANUP_SECRET" -H "Content-Type: application/json" \
#     -d "{\"purge_notifications\":true}"
# Or combine: -d "{\"minutes\":30,\"purge_notifications\":true}"
