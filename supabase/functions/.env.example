# Copy to supabase/functions/.env for local `supabase functions serve` only (gitignored).
# Production: Supabase Dashboard → Project Settings → Edge Functions → Secrets.

# --- SMTP (MailerSend relay) ---
EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=replace_with_smtp_username
SMTP_PASSWORD=replace_with_smtp_password
NOTIFICATION_FROM_EMAIL=EXCH. <noreply@your-trial-subdomain.mlsender.net>

# --- Or HTTP API ---
# MAILERSEND_API_KEY=mlsn_replace_me
# NOTIFICATION_FROM_EMAIL=EXCH. <noreply@your-trial-subdomain.mlsender.net>

# Auth Send Email hook (Dashboard → Authentication → Auth Hooks → generate secret):
# SEND_EMAIL_HOOK_SECRET=v1,whsec_<secret-from-dashboard>
