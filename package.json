{
  "name": "marketplace-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "catalog:import": "node scripts/import-catalog.mjs",
    "catalog:dry-run": "node scripts/import-catalog.mjs --dry-run",
    "kicks:import": "node scripts/import-kicksdb.mjs",
    "kicks:dry-run": "node scripts/import-kicksdb.mjs --dry-run",
    "seed:designer": "node scripts/seed-designer-catalog.mjs",
    "seed:puffer": "node scripts/seed-puffer-catalog.mjs",
    "seed:accessories": "node scripts/seed-accessories-catalog.mjs",
    "supabase": "npx supabase@latest",
    "deploy:send-test-email": "npx supabase@latest functions deploy send-test-email",
    "deploy:email-functions": "npx supabase@latest functions deploy send-test-email && npx supabase@latest functions deploy stripe-webhook --no-verify-jwt && npx supabase@latest functions deploy confirm-checkout-session && npx supabase@latest functions deploy admin-update-trade-status && npx supabase@latest functions deploy create-seller-inbound-label && npx supabase@latest functions deploy create-buyer-outbound-label"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.4"
  }
}
